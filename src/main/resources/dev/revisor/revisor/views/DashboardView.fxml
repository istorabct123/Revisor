<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.canvas.Canvas?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Rectangle?>

<VBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="dev.revisor.revisor.controller.DashboardViewController"
      styleClass="page-root">

    <!-- TOPBAR -->
    <HBox alignment="CENTER_LEFT" spacing="12" styleClass="topbar">
        <Label styleClass="page-title" text="Desempenho" />
        <Label fx:id="tabGeral"   styleClass="tab tab-active" text="Geral"        onMouseClicked="#onTabGeral"   />
        <Label fx:id="tabSemana"  styleClass="tab"            text="Semana"       onMouseClicked="#onTabSemana"  />
        <Label fx:id="tabMateria" styleClass="tab"            text="Por Matéria"  onMouseClicked="#onTabMateria" />
        <Region HBox.hgrow="ALWAYS"/>
        <Button styleClass="btn-ghost-sm" text="↓ Exportar" />
    </HBox>

    <ScrollPane fitToWidth="true" styleClass="content-scroll" VBox.vgrow="ALWAYS">
        <VBox spacing="14" styleClass="content-area">
            <padding><Insets bottom="28" left="20" right="20" top="20"/></padding>

            <!-- ── STAT CARDS ───────────────────────────────────────── -->
            <HBox spacing="12">

                <!-- Questões Resolvidas -->
                <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
                    <HBox alignment="CENTER_LEFT" spacing="6">
                        <Label text="≡" styleClass="stat-icon"/>
                        <Label text="QUESTÕES RESOLVIDAS" styleClass="stat-label"/>
                    </HBox>
                    <Label fx:id="statQuestoes" text="0" styleClass="stat-value"/>
                    <Label fx:id="statHoje"     text="+0 hoje" styleClass="stat-sub"/>
                </VBox>

                <!-- Taxa de Acerto -->
                <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
                    <HBox alignment="CENTER_LEFT" spacing="6">
                        <Label text="✓" styleClass="stat-icon"/>
                        <Label text="TAXA DE ACERTO" styleClass="stat-label"/>
                    </HBox>
                    <Label fx:id="statAcertos" text="0%" styleClass="stat-value"/>
                    <Label fx:id="statAcertosDetalhe" text="0 acertos de 0" styleClass="stat-sub"/>
                </VBox>

                <!-- Sequência -->
                <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
                    <HBox alignment="CENTER_LEFT" spacing="6">
                        <Label text="🔥" styleClass="stat-icon"/>
                        <Label text="SEQUÊNCIA ATUAL" styleClass="stat-label"/>
                    </HBox>
                    <Label fx:id="statSequencia" text="0d" styleClass="stat-value"/>
                    <Label fx:id="statStreakSub" text="Recorde: 0 dias" styleClass="stat-sub"/>
                </VBox>

                <!-- Tempo de Estudo (timer real) -->
                <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
                    <HBox alignment="CENTER_LEFT" spacing="6">
                        <Label text="⏱" styleClass="stat-icon"/>
                        <Label text="TEMPO DE ESTUDO" styleClass="stat-label"/>
                    </HBox>
                    <Label fx:id="statHoras" text="0h 00m 00s" styleClass="stat-value" style="-fx-font-size: 20px;"/>
                    <Label fx:id="statHorasSub" text="hoje nesta sessão" styleClass="stat-sub"/>
                </VBox>

            </HBox>

            <!-- ── LINHA 2: Atividade 7 dias + Donut ─────────────── -->
            <HBox spacing="12">

                <!-- Gráfico de barras – 7 dias -->
                <VBox styleClass="card" HBox.hgrow="ALWAYS">
                    <HBox alignment="CENTER_LEFT" spacing="8" styleClass="card-header">
                        <Label text="📊" styleClass="card-icon"/>
                        <Label text="Atividade dos Últimos 7 Dias" styleClass="card-title"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label fx:id="lblMediaDiaria" text="Média: 0 questões/dia" styleClass="badge-neutral"/>
                    </HBox>
                    <!-- Canvas inserido programaticamente -->
                    <VBox fx:id="barChartBox" style="-fx-padding: 8 16 12 16;" minHeight="140"/>
                </VBox>

                <!-- Donut acertos/erros -->
                <VBox styleClass="card" prefWidth="220" minWidth="200">
                    <HBox alignment="CENTER_LEFT" spacing="8" styleClass="card-header">
                        <Label text="🎯" styleClass="card-icon"/>
                        <Label text="Distribuição" styleClass="card-title"/>
                    </HBox>
                    <VBox fx:id="donutBox" alignment="CENTER" style="-fx-padding: 12 16 16 16;" minHeight="120"/>
                </VBox>

            </HBox>

            <!-- ── TABELA DE MATÉRIAS ─────────────────────────────── -->
            <VBox styleClass="card">
                <HBox alignment="CENTER_LEFT" spacing="8" styleClass="card-header">
                    <Label text="📋" styleClass="card-icon"/>
                    <Label text="Desempenho por Matéria / Assunto" styleClass="card-title"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label fx:id="lblQtdMaterias" text="0 matérias" styleClass="badge-neutral"/>
                </HBox>

                <!-- Cabeçalho da tabela -->
                <HBox styleClass="table-header">
                    <Label text="MATÉRIA / ASSUNTO" prefWidth="220" style="-fx-padding: 0 0 0 14;"/>
                    <Label text="QUESTÕES" prefWidth="80"/>
                    <Label text="ACERTOS"  prefWidth="70"/>
                    <Label text="ERROS"    prefWidth="70"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label text="TAXA" style="-fx-padding: 0 14 0 0;"/>
                </HBox>

                <!-- Linhas dinâmicas -->
                <VBox fx:id="tabelaMaterias" />
            </VBox>

            <!-- ── LINHA 3: Metas + Progresso ───────────────────── -->
            <HBox spacing="12">

                <!-- Metas da Semana -->
                <VBox styleClass="card" HBox.hgrow="ALWAYS">
                    <HBox alignment="CENTER_LEFT" styleClass="card-header">
                        <Label text="📅" styleClass="card-icon"/>
                        <Label text="Metas da Semana" styleClass="card-title"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Button text="Editar" styleClass="btn-ghost-sm"/>
                    </HBox>
                    <VBox fx:id="metasBox" style="-fx-padding: 12 16 16 16;" spacing="10">
                        <Label text="Nenhuma meta definida." styleClass="empty-text"/>
                    </VBox>
                </VBox>

                <!-- Progresso Geral -->
                <VBox styleClass="card" HBox.hgrow="ALWAYS">
                    <HBox alignment="CENTER_LEFT" styleClass="card-header">
                        <Label text="🚀" styleClass="card-icon"/>
                        <Label text="Progresso Geral" styleClass="card-title"/>
                    </HBox>
                    <VBox fx:id="progressoBox" style="-fx-padding: 12 16 16 16;" spacing="14"/>
                </VBox>

            </HBox>

        </VBox>
    </ScrollPane>
</VBox>
