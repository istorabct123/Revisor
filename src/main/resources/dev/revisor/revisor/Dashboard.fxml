<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Rectangle?>

<BorderPane prefHeight="760" prefWidth="1200" styleClass="root-pane" stylesheets="@styles.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="dev.revisor.revisor.controller.MainController">

    <!-- ══════════════════════════════════
         SIDEBAR (LEFT)
    ══════════════════════════════════ -->
    <left>
        <VBox prefWidth="220" styleClass="sidebar">

            <!-- Logo -->
            <VBox styleClass="logo-area">
                <HBox alignment="CENTER_LEFT" spacing="0">
                    <Label styleClass="logo-text" text="Revisor" />
                    <Label styleClass="logo-accent" />
                </HBox>
            </VBox>

            <!-- Navegação Principal -->
            <VBox styleClass="nav-section" VBox.vgrow="ALWAYS">
                <Label styleClass="nav-label" text="NAVEGAÇÃO" />

                <HBox fx:id="navDashboard" styleClass="nav-item nav-active">
                    <Label styleClass="nav-icon" text="⊞" />
                    <Label styleClass="nav-text" />
                </HBox>
                <HBox fx:id="navMateriais" styleClass="nav-item">
                    <Label styleClass="nav-icon" text="📚" />
                    <Label styleClass="nav-text" text="Materiais" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Label styleClass="badge badge-blue" text="12" />
                </HBox>
                <HBox fx:id="navQuestoes" styleClass="nav-item">
                    <Label styleClass="nav-icon" text="✏" />
                    <Label styleClass="nav-text" text="Questões" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Label styleClass="badge badge-warn" text="38" />
                </HBox>
                <HBox fx:id="navDesempenho" styleClass="nav-item">
                    <Label styleClass="nav-icon" text="📊" />
                    <Label styleClass="nav-text" text="Desempenho" />
                </HBox>
                <HBox fx:id="navPlanejamento" styleClass="nav-item">
                    <Label styleClass="nav-icon" text="🗓" />
                    <Label styleClass="nav-text" text="Planejamento" />
                </HBox>
                <HBox fx:id="navRevisoes" styleClass="nav-item">
                    <Label styleClass="nav-icon" text="🔖" />
                    <Label styleClass="nav-text" text="Revisões" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Label styleClass="badge badge-green" text="5" />
                </HBox>

                <!-- Matérias -->
                <Label style="-fx-padding: 16 0 4 8;" styleClass="nav-label" text="MATÉRIAS" />

                <HBox alignment="CENTER_LEFT" spacing="8" styleClass="subject-item">
                    <Rectangle arcHeight="3" arcWidth="3" fill="#4f9cf9" height="8" styleClass="subject-dot" width="8" />
                    <Label styleClass="subject-name" text="Matemática" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Label styleClass="subject-pct" text="72%" />
                </HBox>
                <HBox alignment="CENTER_LEFT" spacing="8" styleClass="subject-item">
                    <Rectangle arcHeight="3" arcWidth="3" fill="#38d9a9" height="8" styleClass="subject-dot" width="8" />
                    <Label styleClass="subject-name" text="Português" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Label styleClass="subject-pct" text="85%" />
                </HBox>
                <HBox alignment="CENTER_LEFT" spacing="8" styleClass="subject-item">
                    <Rectangle arcHeight="3" arcWidth="3" fill="#f093fb" height="8" styleClass="subject-dot" width="8" />
                    <Label styleClass="subject-name" text="História" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Label styleClass="subject-pct" text="44%" />
                </HBox>
                <HBox alignment="CENTER_LEFT" spacing="8" styleClass="subject-item">
                    <Rectangle arcHeight="3" arcWidth="3" fill="#ffd93d" height="8" styleClass="subject-dot" width="8" />
                    <Label styleClass="subject-name" text="Geografia" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Label styleClass="subject-pct" text="31%" />
                </HBox>
                <HBox alignment="CENTER_LEFT" spacing="8" styleClass="subject-item">
                    <Rectangle arcHeight="3" arcWidth="3" fill="#ff6b6b" height="8" styleClass="subject-dot" width="8" />
                    <Label styleClass="subject-name" text="Inglês" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Label styleClass="subject-pct" text="18%" />
                </HBox>

                <Label onMouseClicked="#onAddSubject" styleClass="add-subject-link" text="+ Adicionar matéria" />
            </VBox>

            <!-- User Footer -->
            <HBox alignment="CENTER_LEFT" spacing="10" styleClass="sidebar-footer">
                <StackPane styleClass="user-avatar">
                    <Label styleClass="user-avatar-letter" text="M" />
                </StackPane>
                <VBox spacing="2">
                    <Label styleClass="user-name" text="Meu Perfil" />
                    <Label styleClass="user-role" text="Concurseiro" />
                </VBox>
                <Region HBox.hgrow="ALWAYS" />
                <Label onMouseClicked="#onSettings" styleClass="settings-icon" text="⚙" />
            </HBox>
        </VBox>
    </left>
   <right>
        <StackPane fx:id="contentArea" BorderPane.alignment="CENTER" />
   </right>

</BorderPane>
