<VBox alignment="CENTER" prefHeight="516.0" prefWidth="757.0" spacing="20.0" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="dev.revisor.revisor.HelloController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>

    <Label fx:id="welcomeText" alignment="CENTER" contentDisplay="TOP" prefHeight="92.0" prefWidth="153.0" text="Testando" textAlignment="CENTER" textFill="#d70000" />
    <Button onAction="#onHelloButtonClick" text="Hello!" />
</VBox>
